generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(EDITOR)
  active       Boolean    @default(true)
  lastLogin    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  topLevels       TopLevel[]
  apiConfig       ApiConfig?
  sentInvites     Invite[]
  heygenAvatars   HeygenTrainedAvatar[]
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(EDITOR)
  token       String    @unique @default(cuid())
  invitedById String
  invitedBy   User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model TopLevel {
  id              String           @id @default(cuid())
  name            String
  order           Int              @default(0)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords        Keyword[]
  wordpressConfig WordpressConfig?
  shopifyConfig   ShopifyConfig?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Keyword {
  id         String            @id @default(cuid())
  keyword    String
  goal       String            @default("")
  audience   String            @default("")
  topLevelId String
  topLevel   TopLevel          @relation(fields: [topLevelId], references: [id], onDelete: Cascade)
  results    GeneratedResult[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model GeneratedResult {
  id             String       @id @default(cuid())
  keywordText    String
  title          String
  status         ResultStatus @default(DRAFT)
  previousStatus ResultStatus?
  keywordId      String
  keyword        Keyword      @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  // Persona fields
  demographic  String?  @db.Text
  persona1     String?  @db.Text
  persona2     String?  @db.Text
  persona3     String?  @db.Text
  demoSize1    String?  @db.Text
  demoSize2    String?  @db.Text
  demoSize3    String?  @db.Text

  // Structure fields
  structIntro   String? @db.Text
  structNayami  String? @db.Text
  structP1      String? @db.Text
  structP2      String? @db.Text
  structP3      String? @db.Text
  structCommon  String? @db.Text
  structCta     String? @db.Text
  structMatome  String? @db.Text
  structH2      String? @db.Text

  // Fact check fields
  factCheck       Json?
  targetDecision  String? @db.Text

  article   Article?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id         String        @id @default(cuid())
  status     ArticleStatus @default(READY)
  platform     String?
  publishedUrl String?
  uploadedAt   DateTime?
  resultId   String        @unique
  result     GeneratedResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  sections   ArticleSection[]
  images     ArticleImage[]
  uploadMeta   UploadMeta?
  videoScript  VideoScript?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ArticleSection {
  id        String  @id @default(cuid())
  index     Int
  type      String
  heading   String
  content   String  @db.Text
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, index])
}

model ArticleImage {
  id        String     @id @default(cuid())
  index     Int
  enabled   Boolean    @default(true)
  taste     ImageTaste @default(PHOTO)
  prompt    String     @db.Text
  imageUrl  String?
  articleId String
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  history   ImageHistory[]

  @@unique([articleId, index])
}

model ImageHistory {
  id        String       @id @default(cuid())
  imageUrl  String
  prompt    String       @db.Text
  imageId   String
  image     ArticleImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model WordpressConfig {
  id              String   @id @default(cuid())
  wpUrl           String
  wpUserEncrypted String   @db.Text
  wpPassEncrypted String   @db.Text
  topLevelId      String   @unique
  topLevel        TopLevel @relation(fields: [topLevelId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ShopifyConfig {
  id                    String   @id @default(cuid())
  shopDomain            String
  accessTokenEncrypted  String   @db.Text
  blogId                String   @default("")
  topLevelId            String   @unique
  topLevel              TopLevel @relation(fields: [topLevelId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UploadMeta {
  id            String        @id @default(cuid())
  slug          String
  excerpt       String        @db.Text
  tags          String
  category      String
  formattedHtml String?       @db.LongText
  aiTitle       String?
  publishStatus PublishStatus @default(DRAFT)
  scheduleDate  DateTime?
  articleId     String        @unique
  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model VideoScript {
  id              String               @id @default(cuid())
  title           String
  audioUrl        String?
  audioStatus     String               @default("pending")
  avatarId        String?
  orientation     String               @default("horizontal")
  theme           String               @default("modern-dark")
  heygenVideoId   String?
  heygenVideoUrl  String?
  heygenStatus    String               @default("pending")
  remotionJobId   String?
  remotionVideoUrl String?
  remotionStatus  String               @default("pending")
  articleId       String               @unique
  article         Article              @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sections        VideoScriptSection[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model TtsDictionary {
  id      String @id @default(cuid())
  kanji   String @unique
  reading String
  userId  String
  createdAt DateTime @default(now())
}

model VideoScriptSection {
  id               String      @id @default(cuid())
  sectionNumber    Int
  section          String
  heading          String
  points           String      @db.Text
  type             String      @default("general")
  narration        String      @db.Text
  backgroundKeyword String     @default("")
  visualType       String     @default("avatar")
  visualNote       String     @default("")
  imagePrompt      String     @default("")
  imageUrl         String?
  videoScriptId    String
  videoScript      VideoScript @relation(fields: [videoScriptId], references: [id], onDelete: Cascade)

  @@unique([videoScriptId, sectionNumber])
}

model ApiConfig {
  id                    String   @id @default(cuid())
  claudeApiEncrypted    String?  @db.Text
  openaiApiEncrypted    String?  @db.Text
  geminiApiEncrypted    String?  @db.Text
  googleApiEncrypted    String?  @db.Text
  metaApiEncrypted      String?  @db.Text
  kieApiEncrypted       String?  @db.Text
  pieapiEncrypted       String?  @db.Text
  heygenApiEncrypted    String?  @db.Text
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model HeygenTrainedAvatar {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  imageUrl   String              @db.Text
  imageKey   String?             @db.Text
  groupId    String?
  avatarId   String?
  status     HeygenAvatarStatus  @default(PENDING)
  errorMsg   String?             @db.Text
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([userId])
}

enum HeygenAvatarStatus {
  PENDING
  UPLOADING
  TRAINING
  READY
  FAILED
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum ResultStatus {
  DRAFT
  READY
  KW_DONE
  PERSONA_WIP
  PERSONA_DONE
  STRUCT_WIP
  STRUCT_DONE
  PUBLISHED
  SKIPPED
}

enum ArticleStatus {
  READY
  WRITING
  ARTICLE_DONE
  IMAGING
  IMAGE_DONE
  FORMATTING
  FORMAT_DONE
  UPLOADED
}

enum ImageTaste {
  PHOTO
  TEXT_OVERLAY
  INFOGRAPHIC
  ILLUSTRATION
  CINEMATIC
}

enum PublishStatus {
  PUBLISH
  DRAFT
  SCHEDULE
}
