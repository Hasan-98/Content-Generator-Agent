# ─── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────

# Backend
DATABASE_URL="mysql://user:password@localhost:3306/content_studio"
JWT_SECRET="change-this-to-random-secret"
PORT=3001
FRONTEND_URL="http://localhost:5173"
ANTHROPIC_API_KEY="sk-ant-..."
VALUESERP_API_KEY="your-valueserp-key"
NODE_ENV="development"

# Frontend (Vite prefix required)
VITE_API_URL="http://localhost:3001/api"


# ─── PRODUCTION (Digital Ocean BE + Vercel FE) ────────────────────────────────
# Set these in your Digital Ocean App Platform environment variables UI
#
# DATABASE_URL="mysql://YOUR_USER:YOUR_PASS@db-mysql-xxx.db.ondigitalocean.com:25060/content_studio?ssl-mode=REQUIRED"
# JWT_SECRET="<generate 64-char random string>"
# PORT=3001
# FRONTEND_URL="https://your-app.vercel.app"
# ANTHROPIC_API_KEY="sk-ant-..."
# VALUESERP_API_KEY="your-valueserp-key"
# NODE_ENV="production"
#
# Set this in Vercel → Project → Settings → Environment Variables:
# VITE_API_URL="https://your-backend-name.ondigitalocean.app/api"
